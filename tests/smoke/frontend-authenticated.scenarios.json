{
  "version": 1,
  "scenarios": [
    {
      "id": "home-authenticated",
      "role": "admin",
      "description": "Valida login real y render de Inicio para una cuenta controlada con acceso basico al ERP.",
      "emailEnv": "FRONTEND_AUTH_SMOKE_HOME_EMAIL",
      "passwordEnv": "FRONTEND_AUTH_SMOKE_HOME_PASSWORD",
      "targetPath": "/",
      "expectedPath": "/",
      "expectedHeading": "Bienvenido",
      "requireModuleAccess": true
    },
    {
      "id": "operations-l1-summary",
      "role": "operaciones_l_1",
      "description": "Valida que una cuenta L1 controlada pueda entrar a Resumen de Operaciones.",
      "emailEnv": "FRONTEND_AUTH_SMOKE_OPERATIONS_L1_EMAIL",
      "passwordEnv": "FRONTEND_AUTH_SMOKE_OPERATIONS_L1_PASSWORD",
      "targetPath": "/operaciones/resumen",
      "expectedPath": "/operaciones/resumen",
      "requireModuleAccess": true
    },
    {
      "id": "certificaciones-form",
      "role": "certificaciones",
      "description": "Valida que una cuenta de certificaciones pueda abrir el formulario de certificacion.",
      "emailEnv": "FRONTEND_AUTH_SMOKE_CERTIFICACIONES_EMAIL",
      "passwordEnv": "FRONTEND_AUTH_SMOKE_CERTIFICACIONES_PASSWORD",
      "targetPath": "/certificados",
      "expectedPath": "/certificados",
      "expectedHeading": "Certificacion de Competencias",
      "requireModuleAccess": true
    },
    {
      "id": "instructor-form",
      "role": "instructor",
      "description": "Valida que una cuenta instructor controlada pueda abrir el formulario de certificacion.",
      "emailEnv": "FRONTEND_AUTH_SMOKE_INSTRUCTOR_EMAIL",
      "passwordEnv": "FRONTEND_AUTH_SMOKE_INSTRUCTOR_PASSWORD",
      "targetPath": "/certificados",
      "expectedPath": "/certificados",
      "expectedHeading": "Certificacion de Competencias",
      "requireModuleAccess": true
    }
  ]
}
