# Supabase Configuration (Requeridos)
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_ANON_KEY"
VITE_PUBLIC_APP_URL="https://gestion.busesjm.cl"
VITE_ORION_FUNCTION_NAME="orion-chat"

# Supabase Service Role (Solo requerido para scripts administrativos en Node.js, no en React)
# NUNCA exponer esta llave en VITE_ variables
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"

# BUK Integration (Solo requerido para scripts de sincronización)
BUK_EMPLOYEES_URL="https://YOUR_BUK_DOMAIN/api/v1/employees"
BUK_AREAS_URL="https://YOUR_BUK_DOMAIN/api/v1/organization/areas"
BUK_AUTH_TOKEN="YOUR_BUK_API_TOKEN"

# ORION Edge Function Secrets (Configurar en Supabase Secrets, no en VITE_)
# ORION_LLM_API_KEY="YOUR_PROVIDER_API_KEY"
# ORION_LLM_BASE_URL="https://api.groq.com/openai/v1"
# ORION_LLM_MODEL="llama-3.1-8b-instant"
